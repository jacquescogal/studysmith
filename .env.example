OPENAI_API_KEY=

# Lower-cost reasoning model used for chat, intent classification, and helper generation
OPENAI_WEAK_MODEL=gpt-5.4-mini

# Stronger reasoning model used for cleaned text, study card, and question card generation
OPENAI_STRONG_MODEL=gpt-5.4

# Embedding model for vector search
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# SQLAlchemy database URL for Docker/production
DATABASE_URL=sqlite:///./study.db

# Local development default; production can use Supabase Postgres with pgvector once vector storage is migrated
CHROMA_PATH=./chroma

# Supabase Auth
SUPABASE_URL=
SUPABASE_JWKS_URL=
SUPABASE_JWT_ISSUER=
SUPABASE_JWT_AUDIENCE=authenticated

# Comma-separated emails promoted to admin on first profile creation
ADMIN_EMAILS=
