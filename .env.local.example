OPENAI_API_KEY=

# Lower-cost reasoning model used for chat, intent classification, and helper generation
OPENAI_WEAK_MODEL=gpt-5.4-mini

# Stronger reasoning model used for cleaned text, study card, and question card generation
OPENAI_STRONG_MODEL=gpt-5.4

# Embedding model for vector search
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Local Supabase Postgres from `make supabase-start`
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres

# Local Supabase Auth from `make supabase-start`
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_SECRET_KEY=sb_secret_from_make_supabase_status
SUPABASE_JWKS_URL=http://127.0.0.1:54321/auth/v1/.well-known/jwks.json
SUPABASE_JWT_ISSUER=http://127.0.0.1:54321/auth/v1
SUPABASE_JWT_AUDIENCE=authenticated
FRONTEND_BASE_URL=http://localhost:5173

# Browser-safe Supabase config used by the Vite frontend.
VITE_API_BASE_URL=
VITE_SUPABASE_URL=http://127.0.0.1:54321
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_from_make_supabase_status

# Comma-separated emails promoted to admin on first profile creation
ADMIN_EMAILS=
