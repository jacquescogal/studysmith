OPENAI_API_KEY=

# Model used for chat and intent classification
OPENAI_CHAT_MODEL=gpt-4.1-mini

# Model used for study card and question card generation
OPENAI_GENERATION_MODEL=gpt-4.1

# Embedding model for ChromaDB vector search
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# SQLAlchemy database URL (relative to backend directory)
DATABASE_URL=sqlite:///./study.db

# ChromaDB on-disk path (relative to backend directory)
CHROMA_PATH=./chroma
