OPENAI_API_KEY=

# Lower-cost reasoning model used for chat, intent classification, and helper generation
OPENAI_WEAK_MODEL=gpt-5.4-mini

# Stronger reasoning model used for cleaned text, study card, and question card generation
OPENAI_STRONG_MODEL=gpt-5.4

# Embedding model for vector search
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Remote Supabase Postgres connection string
DATABASE_URL=postgresql://postgres.<project-ref>:<database-password>@aws-0-<region>.pooler.supabase.com:6543/postgres

# Remote Supabase Auth
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SECRET_KEY=sb_secret_<remote-secret-key>
SUPABASE_JWKS_URL=https://<project-ref>.supabase.co/auth/v1/.well-known/jwks.json
SUPABASE_JWT_ISSUER=https://<project-ref>.supabase.co/auth/v1
SUPABASE_JWT_AUDIENCE=authenticated

# Browser-safe Supabase config baked into the frontend at build time.
VITE_API_BASE_URL=
VITE_SUPABASE_URL=https://<project-ref>.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_<remote-publishable-key>

# Comma-separated emails promoted to admin on first profile creation
ADMIN_EMAILS=
